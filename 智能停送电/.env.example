# 复制为 .env 后按需修改。
# 本机 Windows + 本机 MySQL：DB_HOST=127.0.0.1 ，DB_USER/DB_PASSWORD 与 MySQL 一致（可用 setup_mysql_user_admin.bat 建 admin/admin）
# Docker：DB_HOST=mysql ，密码与 docker-compose / MYSQL_ROOT_PASSWORD 一致

MYSQL_ROOT_PASSWORD=ChangeMe_MySQL_Root_2026!
MYSQL_DATABASE=power_control

DB_HOST=mysql
DB_PORT=3306
DB_USER=root
DB_PASSWORD=ChangeMe_MySQL_Root_2026!
DB_NAME=power_control

SECRET_KEY=ChangeMe_Flask_Secret_2026!
LOG_LEVEL=INFO
SESSION_TYPE=filesystem
# SESSION_REDIS_URL=redis://redis:6379/0

MQTT_BROKER=host.docker.internal
MQTT_PORT=1883

# 设备数据来源：mqtt | opcua | both（设备监控走 Kep/OPC 时请用 opcua 或 both）
DEVICE_DATA_SOURCE=opcua

# OPC UA（KepServer），与现场一致；本机无 Kep 可改 mqtt 或 opc.tcp://现场IP:49320
OPCUA_ENDPOINT=opc.tcp://192.168.10.50:49320
OPCUA_NS=2
OPCUA_DEVICE_ID=opcua_device
OPCUA_POLL_INTERVAL=3
OPCUA_NODEIDS=AB.PLC1.AB.Online.刮板机带电,AB.PLC1.AB.Online.刮板机挂锁测试1,AB.PLC1.AB.Online.刮板机挂锁测试2,AB.PLC1.AB.Online.刮板机挂锁测试3
# OPCUA_USERNAME=
# OPCUA_PASSWORD=
# OPCUA_SECURITY_POLICY=None
# OPCUA_SECURITY_MODE=None
# OPCUA_CERT=
# OPCUA_KEY=
# OPCUA_SERVER_CERT=
