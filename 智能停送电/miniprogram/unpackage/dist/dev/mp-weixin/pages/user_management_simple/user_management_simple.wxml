<view class="container"><view class="header"><text class="title">用户管理 (简化版)</text><button bindtap="{{a}}" class="back-btn">返回</button></view><view class="content"><view wx:if="{{b}}" class="loading"><text>加载中...</text></view><view wx:else class="user-list"><view wx:for="{{c}}" wx:for-item="user" wx:key="c" class="user-item"><text class="user-name">{{user.a}}</text><text class="user-role">{{user.b}}</text></view></view><button bindtap="{{d}}" class="refresh-btn">刷新</button></view></view>