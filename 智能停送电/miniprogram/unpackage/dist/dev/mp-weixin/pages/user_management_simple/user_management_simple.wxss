
.container {
	padding: 20rpx;
}
.header {
	display: flex;
	justify-content: space-between;
	align-items: center;
	padding: 20rpx;
	background: #f0f0f0;
	margin-bottom: 20rpx;
}
.title {
	font-size: 32rpx;
	font-weight: bold;
}
.back-btn {
	background: #007AFF;
	color: white;
	padding: 10rpx 20rpx;
	border-radius: 10rpx;
}
.content {
	padding: 20rpx;
}
.loading {
	text-align: center;
	padding: 40rpx;
}
.user-list {
	margin-bottom: 40rpx;
}
.user-item {
	display: flex;
	justify-content: space-between;
	padding: 20rpx;
	border-bottom: 1rpx solid #eee;
}
.user-name {
	font-size: 28rpx;
}
.user-role {
	font-size: 24rpx;
	color: #666;
}
.refresh-btn {
	background: #007AFF;
	color: white;
	padding: 20rpx;
	border-radius: 10rpx;
	width: 100%;
}
