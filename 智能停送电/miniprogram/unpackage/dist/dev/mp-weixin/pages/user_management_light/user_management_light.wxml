<view class="container"><view class="header"><text class="title">用户管理</text><button bindtap="{{a}}" class="back-btn">返回</button></view><view class="content"><view wx:if="{{b}}" class="loading"><text>加载中...</text></view><view wx:else class="user-list"><view wx:for="{{c}}" wx:for-item="user" wx:key="d" class="user-item"><view class="user-info"><text class="user-name">{{user.a}}</text><text class="user-username">@{{user.b}}</text><text class="user-role">{{user.c}}</text></view></view></view><view wx:if="{{d}}" class="stats"><text class="stats-text">共 {{e}} 个用户</text></view><button bindtap="{{g}}" class="refresh-btn" disabled="{{h}}">{{f}}</button></view></view>