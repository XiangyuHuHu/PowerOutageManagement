<view class="approval-container"><view class="header"><view class="header-content"><view class="logo-icon"><text class="icon">📋</text></view><view class="header-text"><text class="title">审批管理</text><text class="subtitle">智能停送电系统 - 调度审批后台</text></view></view></view><view class="stats-container"><view class="stat-item"><text class="stat-number">{{a}}</text><text class="stat-label">待审批</text></view><view class="stat-item"><text class="stat-number">{{b}}</text><text class="stat-label">已审批</text></view><view class="stat-item"><text class="stat-number">{{c}}</text><text class="stat-label">已驳回</text></view></view><view class="content"><view class="filter-section"><view class="filter-item"><text class="filter-label">状态筛选：</text><picker range="{{e}}" bindchange="{{f}}"><view class="picker">{{d}}</view></picker></view><view class="filter-item"><text class="filter-label">类型筛选：</text><picker range="{{h}}" bindchange="{{i}}"><view class="picker">{{g}}</view></picker></view></view><view wx:if="{{j}}" class="loading"><text>加载中...</text></view><view wx:elif="{{k}}" class="empty"><text>暂无申请记录</text></view><view wx:else class="application-list"><view wx:for="{{l}}" wx:for-item="app" wx:key="p" class="application-item" bindtap="{{app.q}}"><view class="app-header"><text class="app-id">#{{app.a}}</text><view class="{{['status-tag', app.c]}}"><text>{{app.b}}</text></view></view><view class="app-content"><view class="app-row"><text class="label">申请人：</text><text class="value">{{app.d}}</text></view><view class="app-row"><text class="label">设备编号：</text><text class="value">{{app.e}}</text></view><view class="app-row"><text class="label">申请原因：</text><text class="value">{{app.f}}</text></view><view class="app-row"><text class="label">申请时间：</text><text class="value">{{app.g}}</text></view></view><view class="app-actions"><button wx:if="{{app.h}}" class="action-btn approve-btn" catchtap="{{app.i}}"> 审批通过 </button><button wx:if="{{app.j}}" class="action-btn reject-btn" catchtap="{{app.k}}"> 驳回申请 </button><button wx:if="{{app.l}}" class="action-btn approve-btn" catchtap="{{app.m}}"> 同意送电 </button><button wx:if="{{app.n}}" class="action-btn reject-btn" catchtap="{{app.o}}"> 拒绝送电 </button></view></view></view></view><view class="footer"><button class="back-btn" bindtap="{{m}}"><text class="icon">←</text><text>返回</text></button></view></view>