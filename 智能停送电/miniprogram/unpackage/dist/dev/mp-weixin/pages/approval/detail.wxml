<view class="detail-container"><view class="header"><view class="header-content"><view class="logo-icon"><text class="icon">📄</text></view><view class="header-text"><text class="title">申请详情</text><text class="subtitle">智能停送电系统 - 申请详情查看</text></view></view><button class="back-btn" bindtap="{{a}}"><text class="icon">←</text><text>返回</text></button></view><view wx:if="{{b}}" class="loading"><text>加载中...</text></view><view wx:elif="{{c}}" class="empty"><text>申请不存在</text></view><view wx:else class="content"><view class="detail-section"><view class="section-title"><text class="icon">📋</text><text>基本信息</text></view><view class="info-grid"><view class="info-item"><text class="label">申请ID：</text><text class="value">#{{d}}</text></view><view class="info-item"><text class="label">申请人：</text><text class="value">{{e}}</text></view><view class="info-item"><text class="label">申请类型：</text><text class="value">{{f}}</text></view><view class="info-item"><text class="label">当前状态：</text><view class="{{['status-tag', h]}}"><text>{{g}}</text></view></view><view class="info-item"><text class="label">申请时间：</text><text class="value">{{i}}</text></view><view class="info-item"><text class="label">设备编号：</text><text class="value">{{j}}</text></view></view></view><view class="detail-section"><view class="section-title"><text class="icon">📝</text><text>申请详情</text></view><view class="detail-content"><view class="detail-row"><text class="label">停电原因：</text><text class="value">{{k}}</text></view><view wx:if="{{l}}" class="detail-row"><text class="label">停电时间：</text><text class="value">{{m}}</text></view><view wx:if="{{n}}" class="detail-row"><text class="label">设备位置：</text><text class="value">{{o}}</text></view><view wx:if="{{p}}" class="detail-row"><text class="label">详细说明：</text><text class="value">{{q}}</text></view></view></view><view wx:if="{{r}}" class="detail-section"><view class="section-title"><text class="icon">📊</text><text>审批记录</text></view><view class="history-list"><view wx:for="{{s}}" wx:for-item="record" wx:key="g" class="history-item"><view class="history-header"><text class="history-time">{{record.a}}</text><view class="{{['history-status', record.c]}}"><text>{{record.b}}</text></view></view><view class="history-content"><text class="history-operator">操作人：{{record.d}}</text><text wx:if="{{record.e}}" class="history-comment">备注：{{record.f}}</text></view></view></view></view><view wx:if="{{t}}" class="action-section"><view class="section-title"><text class="icon">⚡</text><text>操作</text></view><view class="action-buttons"><button wx:if="{{v}}" class="action-btn approve-btn" bindtap="{{w}}"> 审批通过 </button><button wx:if="{{x}}" class="action-btn reject-btn" bindtap="{{y}}"> 驳回申请 </button><button wx:if="{{z}}" class="action-btn approve-btn" bindtap="{{A}}"> 同意送电 </button><button wx:if="{{B}}" class="action-btn reject-btn" bindtap="{{C}}"> 拒绝送电 </button></view></view></view></view>