
.register-container.data-v-bac4a35d {
	min-height: 100vh;
	background: linear-gradient(135deg, #667eea 0%, #764ba2 100%);
	padding: 40rpx;
	display: flex;
	flex-direction: column;
	justify-content: center;
}
.register-header.data-v-bac4a35d {
	text-align: center;
	margin-bottom: 60rpx;
}
.logo.data-v-bac4a35d {
	margin-bottom: 20rpx;
}
.logo-text.data-v-bac4a35d {
	font-size: 48rpx;
	font-weight: bold;
	color: #fff;
}
.subtitle.data-v-bac4a35d {
	font-size: 32rpx;
	color: rgba(255, 255, 255, 0.8);
}
.register-form.data-v-bac4a35d {
	background: #fff;
	border-radius: 20rpx;
	padding: 60rpx 40rpx;
	box-shadow: 0 10rpx 30rpx rgba(0, 0, 0, 0.1);
}
.form-group.data-v-bac4a35d {
	margin-bottom: 40rpx;
}
.label.data-v-bac4a35d {
	display: block;
	font-size: 28rpx;
	color: #333;
	margin-bottom: 20rpx;
	font-weight: 500;
}
.input.data-v-bac4a35d {
	width: 100%;
	height: 80rpx;
	border: 2rpx solid #e1e5e9;
	border-radius: 10rpx;
	padding: 0 20rpx;
	font-size: 28rpx;
	background: #f8f9fa;
	box-sizing: border-box;
}
.input.data-v-bac4a35d:focus {
	border-color: #409eff;
	background: #fff;
}
.picker.data-v-bac4a35d {
	width: 100%;
	height: 80rpx;
	border: 2rpx solid #e1e5e9;
	border-radius: 10rpx;
	background: #f8f9fa;
	display: flex;
	align-items: center;
	padding: 0 20rpx;
	box-sizing: border-box;
}
.picker-text.data-v-bac4a35d {
	font-size: 28rpx;
	color: #333;
}
.register-btn.data-v-bac4a35d {
	width: 100%;
	height: 80rpx;
	background: linear-gradient(135deg, #409eff, #2a6bc5);
	color: #fff;
	border: none;
	border-radius: 10rpx;
	font-size: 32rpx;
	font-weight: 500;
	margin-top: 40rpx;
	display: flex;
	align-items: center;
	justify-content: center;
}
.register-btn.data-v-bac4a35d:disabled {
	background: #ccc;
}
.login-link.data-v-bac4a35d {
	text-align: center;
	margin-top: 40rpx;
}
.login-link text.data-v-bac4a35d {
	color: #409eff;
	font-size: 28rpx;
}
.error-message.data-v-bac4a35d {
	background: #fef0f0;
	border: 1rpx solid #fbc4c4;
	color: #f56c6c;
	padding: 20rpx;
	border-radius: 10rpx;
	margin-top: 20rpx;
	text-align: center;
	font-size: 28rpx;
}

/* 响应式设计 */
@media (max-width: 750rpx) {
.register-container.data-v-bac4a35d {
		padding: 20rpx;
}
.register-form.data-v-bac4a35d {
		padding: 40rpx 30rpx;
}
.logo-text.data-v-bac4a35d {
		font-size: 40rpx;
}
.subtitle.data-v-bac4a35d {
		font-size: 28rpx;
}
}
