<view class="container"><view class="header"><text class="title">用户管理</text><button bindtap="{{a}}" class="back-btn">返回</button></view><view class="content"><view class="stats"><view class="stat-item"><text class="stat-value">{{b}}</text><text class="stat-label">总用户</text></view><view class="stat-item"><text class="stat-value">{{c}}</text><text class="stat-label">管理员</text></view><view class="stat-item"><text class="stat-value">{{d}}</text><text class="stat-label">调度员</text></view><view class="stat-item"><text class="stat-value">{{e}}</text><text class="stat-label">电工</text></view></view><view class="user-list"><view class="list-header"><text class="list-title">用户列表</text><button bindtap="{{g}}" class="refresh-btn" disabled="{{h}}">{{f}}</button></view><view wx:if="{{i}}" class="loading"><text>加载中...</text></view><view wx:elif="{{j}}" class="empty"><text>暂无用户数据</text></view><view wx:else class="users"><view wx:for="{{k}}" wx:for-item="user" wx:key="g" class="user-item"><view class="user-info"><text class="user-name">{{user.a}}</text><text class="user-username">@{{user.b}}</text><text class="user-role">{{user.c}}</text></view><view class="user-actions"><button class="edit-btn" bindtap="{{user.d}}">编辑</button><button wx:if="{{user.e}}" class="delete-btn" bindtap="{{user.f}}">删除</button></view></view></view></view></view><view wx:if="{{l}}" class="dialog-overlay" bindtap="{{D}}"><view class="dialog" catchtap="{{C}}"><view class="dialog-header"><text class="dialog-title">编辑用户</text><button class="close-btn" bindtap="{{m}}">×</button></view><view class="dialog-content"><view class="form-item"><text class="label">用户名</text><input class="input" placeholder="请输入用户名" value="{{n}}" bindinput="{{o}}"/></view><view class="form-item"><text class="label">真实姓名</text><input class="input" placeholder="请输入真实姓名" value="{{p}}" bindinput="{{q}}"/></view><view class="form-item"><text class="label">角色</text><picker class="picker" value="{{s}}" range="{{t}}" bindchange="{{v}}"><text class="picker-text">{{r}}</text></picker></view><view class="form-item"><text class="label">新密码（留空则不修改）</text><input class="input" type="password" placeholder="请输入新密码" value="{{w}}" bindinput="{{x}}"/></view></view><view class="dialog-footer"><button class="cancel-btn" bindtap="{{y}}">取消</button><button class="save-btn" bindtap="{{A}}" disabled="{{B}}">{{z}}</button></view></view></view></view>